<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#111827"
        android:elevation="4dp"
        android:fitsSystemWindows="true"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@android:color/white" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp">

            <!-- 加载进度条 -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="true"
                android:progressTint="#111827"
                android:indeterminateTint="#111827" />

            <!-- 错误提示 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3CD"
                app:strokeColor="#FFC107"
                app:strokeWidth="1dp">
                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:textSize="13sp"
                    android:textColor="#856404" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 账户基本信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_basic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="账户信息"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:id="@+id/row_basic_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="账户名" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_basic_name" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="服务状态" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_basic_status" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="到期时间" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_basic_expire" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E5E7EB" android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="最新连接"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="在线状态" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_online" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="定位状态" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_state" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="协议类型" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_type" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="挂载点" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_mount" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="最后上线" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_login" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="最后下线" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_logout" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="GGA时间" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_gga" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                            android:text="广播时间" android:textSize="13sp" android:textColor="#6B7280" />
                        <TextView android:id="@+id/tv_latest_broadcast" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="—" android:textSize="13sp" android:textColor="#111827" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 时间范围选择卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="使用详情"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- 时间选择行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="开始时间" android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginBottom="2dp" />
                            <TextView
                                android:id="@+id/tv_start_date"
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="10dp"
                                android:textSize="13sp"
                                android:textColor="#111827"
                                android:background="@drawable/bg_date_picker"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="24dp"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:gravity="center"
                            android:textColor="#9CA3AF"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="14dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="结束时间" android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginBottom="2dp" />
                            <TextView
                                android:id="@+id/tv_end_date"
                                android:layout_width="match_parent"
                                android:layout_height="38dp"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="10dp"
                                android:textSize="13sp"
                                android:textColor="#111827"
                                android:background="@drawable/bg_date_picker"
                                android:clickable="true"
                                android:focusable="true" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- 快速范围按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_today"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:text="今天"
                            android:textSize="12sp"
                            android:textColor="#111827"
                            app:strokeColor="#D1D5DB"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_24h"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="6dp"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:text="最近24h"
                            android:textSize="12sp"
                            android:textColor="#111827"
                            app:strokeColor="#D1D5DB"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_range_7d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:text="最近7天"
                            android:textSize="12sp"
                            android:textColor="#111827"
                            app:strokeColor="#D1D5DB"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_query"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:insetTop="0dp" android:insetBottom="0dp"
                        android:text="查询"
                        android:textSize="14sp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="#111827"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 使用统计卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_usage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="使用统计"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- 第一行：连接次数 GGA总数 无效GGA -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_login" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#111827" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="连接次数" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#E5E7EB" android:layout_marginVertical="4dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_gga" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#111827" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="GGA总数" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#E5E7EB" android:layout_marginVertical="4dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_invalid_gga" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#111827" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="无效GGA" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E5E7EB" android:layout_marginBottom="8dp" />

                    <!-- 第二行：平均卫星数 平均延迟 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_avg_sat" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#111827" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="平均卫星数" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#E5E7EB" android:layout_marginVertical="4dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_avg_delay" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#111827" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="平均延迟(ms)" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#E5E7EB" android:layout_marginBottom="8dp" />

                    <!-- 第三行：固定率 浮点率 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_fixed" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#059669" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="固定率" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="match_parent"
                            android:background="#E5E7EB" android:layout_marginVertical="4dp" />
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_stat_floated" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="—"
                                android:textSize="18sp" android:textStyle="bold" android:textColor="#2563EB" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="浮点率" android:textSize="11sp" android:textColor="#6B7280" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 在线时间轴卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_timeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="在线时间轴"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- 时间轴容器，动态填充 TimelineBarView -->
                    <FrameLayout
                        android:id="@+id/fl_timeline"
                        android:layout_width="match_parent"
                        android:layout_height="24dp" />

                    <!-- 图例 -->
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="6dp">
                        <View android:layout_width="14dp" android:layout_height="14dp"
                            android:background="#10B981" android:layout_marginEnd="4dp"
                            android:layout_gravity="center_vertical" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="在线" android:textSize="11sp" android:textColor="#6B7280"
                            android:layout_marginEnd="12dp" />
                        <View android:layout_width="14dp" android:layout_height="14dp"
                            android:background="#D1D5DB" android:layout_marginEnd="4dp"
                            android:layout_gravity="center_vertical" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="离线" android:textSize="11sp" android:textColor="#6B7280" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GGA详情表格卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_state_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GGA详情"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="horizontal">

                        <LinearLayout
                            android:id="@+id/ll_state_table"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </HorizontalScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 连接记录卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_warn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#E5E7EB"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="连接记录"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/ll_warn_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/tv_warn_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="暂无连接记录"
                        android:gravity="center"
                        android:textSize="13sp"
                        android:textColor="#9CA3AF"
                        android:paddingVertical="16dp"
                        android:visibility="gone" />

                    <!-- 翻页 -->
                    <LinearLayout
                        android:id="@+id/ll_warn_pager"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_warn_prev"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:text="上一页"
                            android:textSize="12sp"
                            android:textColor="#111827"
                            app:strokeColor="#D1D5DB"
                            app:cornerRadius="8dp" />

                        <TextView
                            android:id="@+id/tv_warn_page"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:text="1 / 1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_warn_next"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:insetTop="0dp" android:insetBottom="0dp"
                            android:text="下一页"
                            android:textSize="12sp"
                            android:textColor="#111827"
                            app:strokeColor="#D1D5DB"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
